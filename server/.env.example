PORT=5000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
DB_PATH=./data/database.sqlite
CLIENT_URL=http://localhost:9300

# Optional fallback. TheSportsDB is used first to avoid API-Football rate limits.
FOOTBALL_API_KEY=your-football-api-key-here
FOOTBALL_API_URL=https://v3.football.api-sports.io

# Primary free source for team badges and non-realtime player lists
SPORTSDB_API_KEY=123
SPORTSDB_API_URL=https://www.thesportsdb.com/api/v1/json/123
